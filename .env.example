# Rhubarb Environment Configuration
# Copy this file to .env and fill in your actual values

# Environment mode (dev, backtest, paper, live)
RHUBARB_ENV=dev

# Databento API credentials
DATABENTO_API_KEY=your_databento_api_key_here

# FRED API credentials (for macro data)
FRED_API_KEY=your_fred_api_key_here

# Database paths (optional - defaults to data/db.sqlite)
# DATABASE_PATH=data/db.sqlite

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Paper trading (future use)
# PAPER_BROKER_API_KEY=your_paper_broker_key
# PAPER_ACCOUNT_ID=your_paper_account_id

# Live trading (future use - leave blank for now)
# LIVE_BROKER_API_KEY=
# LIVE_ACCOUNT_ID=
